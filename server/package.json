{
    "name": "server",
    "version": "1.0.0",
    "description": "Backend server for the e-commerce system selling electronic components and devices",
    "main": "dist/src/server.js",
    "scripts": {
        "postinstall": "prisma generate",
        "start": "node dist/src/server.js",
        "dev": "node --watch --conditions=development --import tsx ./src/server.ts",
        "serve:ts": "node --conditions=development --import tsx ./src/server.ts",
        "build": "prisma generate && tsc -p tsconfig.json",
        "vercel-build": "prisma generate && tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "eslint src api --ext .js,.mjs,.cjs,.ts,.mts,.cts --format=stylish",
        "prisma": "prisma",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "seed:mock": "node src/database/seeders/seedMockOrdersReviews.js",
        "perf:readonly": "k6 run test/performance-test.js",
        "perf:admin-readonly": "k6 run test/k6-admin-readonly.js",
        "perf:customer-readonly": "k6 run test/k6-customer-readonly.js"
    },
    "imports": {
        "#src/*": {
            "development": "./src/*.ts",
            "default": "./dist/src/*.js"
        }
    },
    "prisma": {
        "schema": "src/database/prisma/schema.prisma"
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/client": "^7.8.0",
        "@vercel/blob": "^2.4.0",
        "axios": "^1.17.0",
        "bcryptjs": "^3.0.3",
        "body-parser": "^2.2.2",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "csrf-csrf": "^4.0.3",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "fs": "0.0.1-security",
        "jsonwebtoken": "^9.0.3",
        "lusca": "^1.7.0",
        "mongodb": "^7.2.0",
        "multer": "2.1.1",
        "mysql": "^2.18.1",
        "mysql2": "^3.22.5",
        "p-limit": "^7.3.0",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "path": "^0.12.7",
        "pino": "^10.3.1",
        "sharp": "^0.34.5",
        "socks": "^2.8.9",
        "streamifier": "^0.1.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.9.2",
        "@types/passport": "^1.0.17",
        "@types/passport-google-oauth20": "^2.0.16",
        "eslint": "^10.4.1",
        "eslint-plugin-react": "^7.37.5",
        "globals": "^17.6.0",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.3",
        "prisma": "^7.8.0",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1"
    }
}
