{
    "name": "server",
    "version": "1.0.0",
    "description": "Backend server for the e-commerce system selling electronic components and devices",
    "main": "dist/src/app.js",
    "scripts": {
        "start": "node dist/src/app.js",
        "dev": "tsx watch src/app.ts",
        "serve:ts": "tsx src/app.ts",
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "eslint src api --ext .js,.mjs,.cjs,.ts,.mts,.cts --format=stylish",
        "seed:mock": "node scripts/seedMockOrdersReviews.js",
        "perf:readonly": "k6 run test/performance-test.js",
        "perf:admin-readonly": "k6 run test/k6-admin-readonly.js",
        "perf:customer-readonly": "k6 run test/k6-customer-readonly.js"
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@vercel/blob": "^2.3.3",
        "axios": "^1.16.1",
        "bcryptjs": "^3.0.3",
        "body-parser": "^2.2.2",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "csrf-csrf": "^4.0.3",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "fs": "0.0.1-security",
        "jsonwebtoken": "^9.0.3",
        "lusca": "^1.7.0",
        "mongodb": "^7.2.0",
        "multer": "2.1.1",
        "mysql": "^2.18.1",
        "mysql2": "^3.22.3",
        "p-limit": "^7.3.0",
        "path": "^0.12.7",
        "sharp": "^0.34.5",
        "streamifier": "^0.1.1",
        "vercel": "^54.1.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.9.0",
        "eslint": "^10.4.0",
        "eslint-plugin-react": "^7.37.5",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "tsx": "^4.22.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.3"
    }
}
