{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "rootDir": ".",
        "outDir": "dist",
        "allowJs": true,
        "checkJs": false,
        "strict": false,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": ["node", "express"]
    },
    "include": ["api/**/*", "src/**/*"],
    "exclude": ["dist", "node_modules", "test", "scripts"]
}
